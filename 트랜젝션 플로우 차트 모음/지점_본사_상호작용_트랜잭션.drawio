        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart LR\n    classDef startEnd fill:#F3E5F5,stroke:#8E24AA,stroke-width:3px,color:#000;\n    classDef normal fill:#FFF,stroke:#757575,stroke-width:2px,color:#000;\n    classDef decision fill:#FFFDE7,stroke:#FBC02D,stroke-width:2px,color:#000;\n    classDef option fill:#E8F5E9,stroke:#4CAF50,stroke-width:2px,stroke-dasharray: 5 5,color:#000;\n\n    START([▶ 시작: 🏢 본사 관리자 세션 시작]) --&gt; H_Home[본사 통합 대시보드]\n\n    subgraph TRX_H1 [신규 지점 온보딩 자동화]\n        H_Home -.-&gt;|메뉴 1| H_Auto([신규 지점 등록 및 계정 발급])\n        H_Auto --&gt; SendLink[지점장에게 정보 입력 폼 링크 발송]\n        SendLink --&gt; WaitInfo{지점장 입력 대기}\n        WaitInfo --&gt;|수신 완료| Approve[본사 최종 검토 및 시스템 승인]\n        Approve --&gt;|등록 완료| H_Home\n    end\n\n    subgraph TRX_H2 [통합 물류 및 배송 관제]\n        H_Home -.-&gt;|메뉴 2| H_Logi([물류 발주 승인 및 상태 관리])\n        H_Logi --&gt; LogiState{배송 상태 변경 처리}\n        LogiState --&gt; L_Prep[📦 배송 준비] --&gt; L_Ship[🚚 배송 중] --&gt; L_Done[✅ 배송 완료 및 지점 자동 알림]\n        L_Done --&gt;|처리 완료| H_Home\n    end\n\n    subgraph TRX_H3 [다차원 통계 및 마케팅]\n        H_Home -.-&gt;|메뉴 3| H_Stat([정밀 통계 및 리포트 추출])\n        H_Stat --&gt; StatList[매출: 지점/상품/시간/전체 &lt;br&gt; 지출: 지점/전체 &lt;br&gt; 기간별 종합 통계]\n        \n        H_Home -.-&gt;|메뉴 4| H_Promo([이벤트 배너 및 쿠폰 일괄 발행])\n        StatList &amp; H_Promo --&gt;|확인 완료| H_Home\n    end\n\n    subgraph TRX_H4 [지점 소통 관리]\n        H_Home -.-&gt;|메뉴 5| H_Chat([지점 공지 발송 및 실시간 1:1 상담])\n        H_Chat --&gt;|답변 완료| H_Home\n    end\n\n    H_Home --&gt; Logout([시스템 로그아웃]) --&gt; END([■ 종료: 본사 세션 파기])\n\n    class START,END startEnd;\n    class H_Home,SendLink,Approve,L_Prep,L_Ship,L_Done,StatList,Logout normal;\n    class WaitInfo,LogiState decision;\n    class H_Auto,H_Logi,H_Stat,H_Promo,H_Chat option;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="FSB1TZbUvpWP7SDFtI5z-123">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
